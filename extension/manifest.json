{
  "manifest_version": 3,
  "name": "itchcord",
  "version": "1.0.0",
  "description": "Discord rich presence for itch.io browser games",
  "permissions": ["tabs", "scripting", "activeTab"],
  "host_permissions": ["*://*.itch.io/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["*://*.itch.io/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
